# Port du serveur de l'API
PORT=3000

# Base de données PostgreSQL (URL de connexion)
# Exemple local : postgresql://user:password@localhost:5432/nom_base
# Exemple Neon  : postgresql://user:password@ep-nom-serveur.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/mesures_db

# SSL (pour PostgreSQL local sans SSL, mettre à false)
DATABASE_SSL=false

# Clé secrète JWT
JWT_SECRET=votre_cle_secrete_ultra_longue_et_aleatoire

# Configuration SMTP pour l'envoi d'emails (OTP et alertes)
# Exemple pour Gmail :
SMTP_HOST=smtp.gmail.com
# Port 465 pour une connexion sécurisée (implicit TLS), 587 pour STARTTLS
SMTP_PORT=465
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_d_application
SMTP_FROM=Surveillance Salle Serveur <votre_email@gmail.com>

# Liste des emails recevant les alertes de priorité haute (séparés par des virgules)
EMAIL_DESTINATAIRES=admin@example.com,tech@example.com
